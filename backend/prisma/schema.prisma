generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id               String              @id @default(cuid())
  appleSubject     String              @unique
  email            String?
  subscriptionTier SubscriptionTier    @default(FREE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  profile          UserProfile?
  sessions         SleepSession[]
  heartRates       HeartRateData[]
  restRituals      RestRitual[]
  conversations    VoiceConversation[]
  memories         UserMemory[]
}

enum SubscriptionTier {
  FREE
  MONTHLY
  YEARLY
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  voiceId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SleepSession {
  id        String    @id @default(cuid())
  userId    String
  startedAt DateTime
  endedAt   DateTime?
  restScore Int?
  phases    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HeartRateData {
  id        String   @id @default(cuid())
  userId    String
  bpm       Float
  timestamp DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model RestRitual {
  id        String    @id @default(cuid())
  userId    String
  type      String    // e.g., "daytime_pause", "breathing"
  startedAt DateTime
  endedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VoiceConversation {
  id              String   @id @default(cuid())
  userId          String
  messages        Json
  sessionComplete Boolean  @default(false)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserMemory {
  id         String     @id @default(cuid())
  userId     String
  kind       MemoryKind
  content    String
  source     String
  metadata   Json?
  embedding  Json       // Using Json for now, but will leverage pgvector via SQL in RAG logic
  salience   Float      @default(0.5)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([userId, createdAt])
}

enum MemoryKind {
  voice_disclosure
  sleep_summary
  habit
  preference
  concern
  stress_event
  system_summary
}

